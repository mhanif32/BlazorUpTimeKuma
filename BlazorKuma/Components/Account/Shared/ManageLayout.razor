@inherits LayoutComponentBase
@layout BlazorKuma.Components.Layout.MainLayout

<div class="container-fluid py-4">
    @* Page Header *@
    <div class="mb-4">
        <h2 class="text-white fw-bold mb-1">Account Settings</h2>
        <p class="text-muted small">Manage your security, profile, and data integrity.</p>
    </div>

    <div class="row">
        @* Left Sidebar Navigation *@
        <div class="col-xl-3 col-lg-4 mb-4">
            <div class="kuma-card p-0 shadow-sm border-0">
                <div class="card-header bg-dark-subtle border-bottom border-secondary py-3 px-4">
                    <h6 class="m-0 text-white fw-bold"><i class="bi bi-list me-2"></i>Menu</h6>
                </div>
                <div class="p-2">
                    <ManageNavMenu />
                </div>
            </div>
        </div>

        @* Right Side Content Area *@
        <div class="col-xl-9 col-lg-8">
            @* The individual pages (Profile, 2FA, etc.) already have their own cards now *@
            @Body
        </div>
    </div>
</div>