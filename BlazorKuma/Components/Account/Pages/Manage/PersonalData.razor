@page "/Account/Manage/PersonalData"

@inject IdentityUserAccessor UserAccessor

<PageTitle>Personal Data - BlazorKuma</PageTitle>

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-xl-6">
            <div class="kuma-card">
                <div class="d-flex align-items-center mb-4">
                    <div class="status-up me-2"></div>
                    <h4 class="text-white m-0 fw-bold">Manage Personal Data</h4>
                </div>

                <StatusMessage />

                <div class="text-muted mb-4">
                    <p>Your **TechUnited** account contains personal configuration and identity data. You have the right to export or permanently erase this information from our systems.</p>
                </div>

                <div class="d-flex flex-column gap-3">
                    @* Download Action *@
                    <div class="p-3 rounded border border-secondary bg-dark-subtle">
                        <h6 class="text-white mb-2"><i class="bi bi-download me-2 text-success"></i> Export Data</h6>
                        <p class="small text-muted mb-3">Download a full archive of your account profile and activity logs for your records.</p>
                        <form action="Account/Manage/DownloadPersonalData" method="post">
                            <AntiforgeryToken />
                            <button class="btn btn-success px-4 fw-bold" type="submit">Download Archive</button>
                        </form>
                    </div>

                    @* Delete Action *@
                    <div class="p-3 rounded border border-danger-subtle bg-dark-subtle">
                        <h6 class="text-danger mb-2"><i class="bi bi-trash3 me-2"></i> Account Termination</h6>
                        <p class="small text-muted mb-3">Permanently remove your account and all associated monitor configurations. This action is irreversible.</p>
                        <a href="Account/Manage/DeletePersonalData" class="btn btn-outline-danger px-4">Delete My Account</a>
                    </div>
                </div>
            </div>
        </div>

        @* Policy Sidebar *@
        <div class="col-xl-4 mt-4 mt-xl-0">
            <div class="kuma-card border-dashed" style="border-style: dashed; opacity: 0.8;">
                <h5 class="text-white mb-3"><i class="bi bi-shield-lock me-2"></i>Privacy & Compliance</h5>
                <p class="text-muted small">
                    Data management is handled in accordance with our security protocols.
                    Termination of an account will result in the immediate cessation of all active **TechUnited.Monitor** nodes associated with this identity.
                </p>
                <div class="mt-3 pt-3 border-top border-secondary">
                    <span class="badge bg-secondary opacity-50">GDPR Compliant</span>
                    <span class="badge bg-secondary opacity-50 ms-2">Data Portability Active</span>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        _ = await UserAccessor.GetRequiredUserAsync(HttpContext);
    }
}