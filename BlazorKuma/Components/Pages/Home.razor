@page "/"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using BlazorKuma.Models
@using BlazorKuma.Data
@attribute [Authorize]
@inject IDbContextFactory<ApplicationDbContext> DbFactory
@inject NavigationManager Nav
@implements IDisposable
@inject SslCheckService SslService

<PageTitle>Dashboard - BlazorKuma</PageTitle>

<div class="kuma-container p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-white m-0">🚀 Infrastructure</h2>
        <button class="btn btn-success px-4 fw-bold" @onclick='() => Nav.NavigateTo("/add")'>+ Add Monitor</button>
    </div>

    @if (monitors == null)
    {
        <div class="d-flex justify-content-center mt-5">
            <div class="spinner-border text-success" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!monitors.Any())
    {
        <div class="text-center mt-5 p-5 kuma-card">
            <h4 class="text-muted">No monitors found.</h4>
            <p>Start monitoring your TechUnited services by adding your first URL.</p>
        </div>
    }
    else
    {
        <div class="row g-4 dashboard-grid">
            @foreach (var m in monitors)
            {
                <div class="col-12 col-lg-6">
                    <div class="kuma-card h-100 d-flex flex-column @(m.IsPaused ? "paused-opacity" : "")">
                        <div class="card-body p-0 flex-grow-1">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div class="text-truncate me-2">
                                    <h5 class="m-0 text-white text-truncate fw-bold">@m.Name</h5>
                                    <small class="text-muted text-truncate d-block">@m.Target</small>
                                </div>
                                <div class="status-badge @(m.IsPaused ? "bg-secondary" : m.IsUp ? "bg-success" : "bg-danger")">
                                    @(m.IsPaused ? "PAUSED" : m.IsUp ? "UP" : "DOWN")
                                </div>
                            </div>

                            <div class="mt-4">
                                <div class="d-flex justify-content-between align-items-end mb-1">
                                    <small class="text-muted" style="font-size: 0.75rem;">Response Time</small>
                                    <small class="text-success fw-bold" style="font-size: 0.75rem;">
                                        @(m.Heartbeats != null && m.Heartbeats.Any() ? m.Heartbeats.Last().LatencyMs + "ms" : "---")
                                    </small>
                                </div>

                                <svg viewBox="0 0 100 35" class="sparkline-svg w-100" preserveAspectRatio="none" style="height: 60px;">
                                    <polyline fill="none"
                                              stroke="var(--kuma-green)"
                                              stroke-width="2"
                                              stroke-linecap="round"
                                              stroke-linejoin="round"
                                              points="@GetSparklinePoints(m.Heartbeats)" />
                                </svg>
                            </div>

                            <div class="heartbeat-bar mt-3 d-flex gap-1">
                                @for (int i = 0; i < 20; i++)
                                {
                                    var h = m.Heartbeats?.ElementAtOrDefault(i);
                                    <div class="tick flex-grow-1 @(h == null ? "tick-empty" : (h.IsUp ? "tick-up" : "tick-down"))"></div>
                                }
                            </div>
                        </div>

                        <div class="mt-3 p-2 border-top border-secondary small">
                            <div class="d-flex justify-content-between align-items-center">
                                <span class="text-muted">SSL Status: <strong class="text-white">@DomainName</strong></span>
                                <span class="badge @(sslValid ? "bg-success" : "bg-danger")">
                                    @(sslValid ? "SECURE" : "ERROR")
                                </span>
                            </div>
                        </div>

                        <div class="mt-auto pt-3 d-flex gap-2 justify-content-end align-items-center">
                            <button class="btn btn-sm btn-outline-secondary border-0 p-1" @onclick="() => TogglePause(m)" title="Pause/Resume">
                                @(m.IsPaused ? "▶️" : "⏸️")
                            </button>
                            <button class="btn btn-sm btn-outline-info border-0 d-flex align-items-center gap-1" @onclick='() => Nav.NavigateTo($"/edit/{m.Id}")'>
                                <i class="bi bi-pencil-square"></i><span>Edit</span>
                            </button>
                            <button class="btn btn-sm btn-outline-danger border-0 d-flex align-items-center gap-1" @onclick="() => DeleteMonitor(m)">
                                <i class="bi bi-trash3"></i><span class="text-danger">Delete</span>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<BlazorKuma.Models.MonitorItem>? monitors;
    private CancellationTokenSource _cts = new();

    private string DomainName = "techunited.net";
    private bool sslValid;
    private string issuer = "";
    private DateTime expiryDate;
    private bool isExpiringSoon => expiryDate < DateTime.Now.AddDays(30);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 1. SSL Check (Safe)
            var sslResult = await SslService.GetSslDetailsAsync(DomainName);
            sslValid = sslResult.IsValid;
            issuer = sslResult.Issuer;
            expiryDate = sslResult.ExpiryDate;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"SSL Handshake Failed: {ex.Message}");
        }

        try
        {
            // 2. Initial Data Load
            await LoadData();

            // 3. Start Background Polling
            _ = StartRealTimeUpdates();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Data Loading Failed: {ex.Message}");
        }
    }

    private async Task StartRealTimeUpdates()
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(15));
        try
        {
            while (await timer.WaitForNextTickAsync(_cts.Token))
            {
                await InvokeAsync(async () =>
                {
                    await LoadData();
                    StateHasChanged();
                });
            }
        }
        catch (OperationCanceledException) { }
    }

    private async Task LoadData()
    {
        using var db = await DbFactory.CreateDbContextAsync();

        // Using .Select (Projection) forces the database to filter the heartbeats
        // before sending any data over the network.
        monitors = await db.Monitors
            .Select(m => new BlazorKuma.Models.MonitorItem
            {
                Id = m.Id,
                Name = m.Name,
                Target = m.Target,
                IsUp = m.IsUp,
                IsPaused = m.IsPaused,
                LastCheck = m.LastCheck,
                IntervalSeconds = m.IntervalSeconds,
                // SQL will only return the top 20 most recent heartbeats
                Heartbeats = m.Heartbeats
                    .OrderByDescending(h => h.Timestamp)
                    .Take(20)
                    .OrderBy(h => h.Timestamp)
                    .ToList()
            })
            .AsNoTracking() // Recommended for read-only dashboards to save memory
            .ToListAsync();
    }

    private async Task TogglePause(MonitorItem monitor)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        var dbMonitor = await db.Monitors.FindAsync(monitor.Id);
        if (dbMonitor != null)
        {
            dbMonitor.IsPaused = !dbMonitor.IsPaused;
            await db.SaveChangesAsync();
            await LoadData();
        }
    }

    private async Task DeleteMonitor(MonitorItem monitor)
    {
        using var db = await DbFactory.CreateDbContextAsync();
        db.Monitors.Remove(monitor);
        await db.SaveChangesAsync();
        await LoadData();
    }

    private string GetSparklinePoints(List<HeartbeatRecord>? heartbeats)
    {
        if (heartbeats == null || heartbeats.Count < 2) return "0,15 100,15";

        double width = 100, height = 30;

        // Use DefaultIfEmpty to prevent crash on empty list
        var maxLatency = heartbeats.Select(h => h.LatencyMs).DefaultIfEmpty(50).Max();
        if (maxLatency < 10) maxLatency = 50;

        var points = heartbeats.Select((h, i) =>
            $"{(double)i / (heartbeats.Count - 1) * width:F1},{Math.Clamp(height - ((double)h.LatencyMs / (double)maxLatency * height), 2, height - 2):F1}");

        return string.Join(" ", points);
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}