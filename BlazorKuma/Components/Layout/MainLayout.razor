@using Microsoft.AspNetCore.Components.Authorization
@inherits LayoutComponentBase

<AuthorizeView>
    <Authorized>
        @* --- FULL DASHBOARD FOR LOGGED-IN OPERATORS --- *@
        <div class="page">
            <div class="sidebar">
                <NavMenu />
            </div>

            <main class="flex-grow-1 d-flex flex-column" style="min-width: 0;">
                <div class="top-row px-4 border-bottom border-secondary border-opacity-10">
                    <span class="text-muted small fw-medium">TechUnited Monitoring System v1.1</span>

                    <div class="ms-auto d-flex align-items-center">
                        <div class="d-flex align-items-center bg-dark bg-opacity-50 px-3 py-1 rounded-pill border border-secondary border-opacity-25">
                            <span class="status-up me-2"></span>
                            <span class="text-success small fw-bold" style="font-size: 0.75rem; letter-spacing: 0.5px;">SYSTEM OPERATIONAL</span>
                        </div>
                    </div>
                </div>

                <article class="content px-4 py-4 overflow-auto bg-color">
                    @Body
                </article>
            </main>
        </div>
    </Authorized>
    <NotAuthorized>
        @* --- RAW CONTENT FOR LOGIN PAGE (NO SIDEBAR) --- *@
        <main class="d-flex align-items-center justify-content-center vh-100 bg-black">
            @Body
        </main>
    </NotAuthorized>
</AuthorizeView>