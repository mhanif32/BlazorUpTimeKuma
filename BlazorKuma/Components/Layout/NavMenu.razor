@implements IDisposable
@inject NavigationManager NavigationManager
@using BlazorKuma.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.Authorization
@inject IDbContextFactory<ApplicationDbContext> DbFactory

@* --- Sidebar Header / Branding --- *@
<div class="top-row ps-3 navbar navbar-dark border-bottom border-secondary">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold d-flex align-items-center" href="">
            <div class="status-up me-2" style="width: 10px; height: 10px;"></div>
            <span class="text-white">BlazorKuma</span>
        </a>
    </div>
</div>

<div class="nav-scrollable">
    <nav class="nav flex-column h-100 justify-content-between">
        <div>
            @* --- Main Navigation --- *@
            <div class="nav-item px-3 mt-2">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="bi bi-speedometer2 me-2" aria-hidden="true"></span> Dashboard
                </NavLink>
            </div>

            @* --- Infrastructure Categories --- *@
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="databases">
                    <span class="bi bi-database-fill me-2 text-info" aria-hidden="true"></span> Databases
                </NavLink>
            </div>

            <div class="nav-item px-3">
                <NavLink class="nav-link" href="api-console">
                    <span class="bi bi-code-slash me-2 text-warning" aria-hidden="true"></span> API Console
                </NavLink>
            </div>

            @* --- Notifications & Records --- *@
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="notifications">
                    <div class="d-flex align-items-center justify-content-between w-100">
                        <div>
                            <span class="bi bi-bell-fill me-2 @(unreadCount > 0 ? "text-warning pulse-bell" : "text-muted")" aria-hidden="true"></span> Records
                        </div>
                        @if (unreadCount > 0)
                        {
                            <span class="badge rounded-pill bg-danger" style="font-size: 0.7rem; padding: 0.35em 0.65em;">@unreadCount</span>
                        }
                    </div>
                </NavLink>
            </div>

            @* --- Admin-Only Actions --- *@
            <AuthorizeView Roles="Admin">
                <Authorized>
                    <div class="nav-item px-3 mt-2">
                        <NavLink class="nav-link bg-dark-subtle rounded text-success" href="add">
                            <span class="bi bi-plus-circle-fill me-2" aria-hidden="true"></span> Add Monitor
                        </NavLink>
                    </div>
                </Authorized>
            </AuthorizeView> @* <-- Ensure this is exactly here *@

            <hr class="mx-3 border-secondary opacity-25" />
        </div>

        @* --- User Profile & Auth Section (Sticky Bottom) --- *@
        <div class="pb-3 mt-auto">
            @* We use Context="authContext" to fix the RZ9999 error *@
            <AuthorizeView Context="authContext">
                <Authorized>
                    <div class="nav-item px-3 mb-2">
                        <NavLink class="nav-link user-profile-link py-1" href="Account/Manage">
                            <div class="d-flex flex-column overflow-hidden">
                                <span class="small text-muted" style="font-size: 0.65rem; text-transform: uppercase;">Operator</span>
                                <span class="text-white fw-bold text-truncate" title="@authContext.User.Identity?.Name">
                                    <i class="bi bi-person-circle me-2 text-success"></i>@authContext.User.Identity?.Name
                                </span>
                            </div>
                        </NavLink>
                    </div>

                    <div class="nav-item px-3">
                        <form action="Account/Logout" method="post">
                            <AntiforgeryToken />
                            <input type="hidden" name="ReturnUrl" value="@currentUrl" />
                            <button type="submit" class="nav-link w-100 text-start border-0 bg-transparent text-danger logout-button">
                                <span class="bi bi-box-arrow-left me-2" aria-hidden="true"></span> Logout
                            </button>
                        </form>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link border border-success rounded text-success text-center justify-content-center" href="Account/Login">
                            <span class="bi bi-person-badge-fill me-2" aria-hidden="true"></span> Login
                        </NavLink>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </nav>
</div>

@code {
    private string? currentUrl;
    private int unreadCount = 0;

    protected override async Task OnInitializedAsync()
    {
        currentUrl = NavigationManager.ToBaseRelativePath(NavigationManager.Uri);
        NavigationManager.LocationChanged += OnLocationChanged;
        await RefreshNotificationCount();
    }

    private async Task RefreshNotificationCount()
    {
        try
        {
            using var db = await DbFactory.CreateDbContextAsync();
            unreadCount = await db.Notifications.CountAsync(n => !n.IsRead);
        }
        catch { /* Fallback for DB or migration issues */ }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        currentUrl = NavigationManager.ToBaseRelativePath(e.Location);
        // Refresh count on every navigation to keep data fresh
        _ = InvokeAsync(async () =>
        {
            await RefreshNotificationCount();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}